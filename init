#!/usr/bin/env bash
set -euo pipefail

read -rp "Library name: " LIB_NAME
read -rp "Library description: " LIB_DESCRIPTION

echo "Python versions: https://devguide.python.org/versions/"
read -rp "Minimum Python version: " PYTHON_VERSION

uv init \
  --lib \
  --name "$LIB_NAME" \
  --description "$LIB_DESCRIPTION" \
  --python "$PYTHON_VERSION"

# Update README.md: replace header and first line with lib name and description
README_TAIL=$(tail -n +3 README.md)
printf '# %s\n%s\n\n%s\n' "$LIB_NAME" "$LIB_DESCRIPTION" "$README_TAIL" > README.md

uv venv --python "$PYTHON_VERSION"

uv add --dev pytest pytest-cov ruff

git add -A
echo git commit -m "Init ${LIB_NAME} library"

echo
echo "Done! ${LIB_NAME} is ready. Activate the venv with: source .venv/bin/activate"
