#!/usr/bin/env bash
set -euo pipefail

read -rp "Library name: " LIB_NAME
read -rp "Library description: " LIB_DESCRIPTION

echo "Python versions: https://devguide.python.org/versions/"
read -rp "Python versions to support, lowest first (e.g. 3.10 3.11 3.12): " PYTHON_VERSIONS_INPUT

IFS=' ' read -ra PYTHON_VERSIONS <<< "$PYTHON_VERSIONS_INPUT"
MIN_VERSION="${PYTHON_VERSIONS[0]}"

uv init \
  --lib \
  --name "$LIB_NAME" \
  --description "$LIB_DESCRIPTION" \
  --python "$MIN_VERSION"

# Add license and URLs to pyproject.toml
sed -i "s/^readme = .*/&\nlicense = { file = \"LICENSE\" }/" pyproject.toml
cat >> pyproject.toml << EOF

[project.urls]
Homepage = "https://github.com/austin-bowen/${LIB_NAME}"
Issues = "https://github.com/austin-bowen/${LIB_NAME}/issues"
EOF

uv sync

uv add --dev pytest pytest-cov ruff

# Create GitHub Actions workflow
VERSIONS_JSON=$(printf '"%s", ' "${PYTHON_VERSIONS[@]}" | sed 's/, $//')
sed -i "s/__PYTHON_VERSIONS__/${VERSIONS_JSON}/" .github/workflows/check.yml.template
git mv .github/workflows/check.yml.template .github/workflows/check.yml

# Update README.md
printf '# %s\n%s\n\n## Installation\n```\npip install %s\n```\n' \
  "$LIB_NAME" \
  "$LIB_DESCRIPTION" \
  "$LIB_NAME" \
  > README.md

git add -A

echo
echo "Done! ${LIB_NAME} is ready. Activate the venv with: source .venv/bin/activate"
