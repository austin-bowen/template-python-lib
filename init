#!/usr/bin/env bash
set -euo pipefail

read -rp "Library name: " LIB_NAME
read -rp "Library description: " LIB_DESCRIPTION

echo "Python versions: https://devguide.python.org/versions/"
read -rp "Python versions to support, lowest first (e.g. 3.10 3.11 3.12): " PYTHON_VERSIONS_INPUT

IFS=' ' read -ra PYTHON_VERSIONS <<< "$PYTHON_VERSIONS_INPUT"
MIN_VERSION="${PYTHON_VERSIONS[0]}"

# This will create src/ and pyproject.toml
uv init \
  --lib \
  --name "$LIB_NAME" \
  --description "$LIB_DESCRIPTION" \
  --python "$MIN_VERSION"

# Add license to pyproject.toml
sed -i "s/^readme = .*/&\nlicense = { file = \"LICENSE\" }/" pyproject.toml

# Add classifiers to pyproject.toml
CLASSIFIERS_TMP=$(mktemp)
{
    printf 'classifiers = [\n'
    printf '    "License :: OSI Approved :: MIT License",\n'
    printf '    "Operating System :: OS Independent",\n'
    printf '    "Programming Language :: Python",\n'
    for v in "${PYTHON_VERSIONS[@]}"; do
        printf '    "Programming Language :: Python :: %s",\n' "$v"
    done
    printf ']\n'
} > "$CLASSIFIERS_TMP"
sed -i "/^dependencies = \[\]/r $CLASSIFIERS_TMP" pyproject.toml
rm "$CLASSIFIERS_TMP"

# Add project URLs to pyproject.toml
cat >> pyproject.toml << EOF

[project.urls]
Homepage = "https://github.com/austin-bowen/${LIB_NAME}"
Issues = "https://github.com/austin-bowen/${LIB_NAME}/issues"
EOF

# This creates the .venv and adds dev dependencies
uv sync
uv add --dev pytest pytest-cov ruff

# Create GitHub Actions workflow to run `bin/check`
VERSIONS_JSON=$(printf '"%s", ' "${PYTHON_VERSIONS[@]}" | sed 's/, $//')
sed -i "s/__PYTHON_VERSIONS__/${VERSIONS_JSON}/" .github/workflows/check.yml.template
git mv .github/workflows/check.yml.template .github/workflows/check.yml

# Update README.md
printf '# %s\n%s\n\n## Installation\n```\npip install %s\n```\n' \
  "$LIB_NAME" \
  "$LIB_DESCRIPTION" \
  "$LIB_NAME" \
  > README.md

# Delete this init script
git rm init

# Add and show all changed files
git add -A
git status

read -rp "Commit changes? [y/N] " DO_COMMIT
if [[ "${DO_COMMIT,,}" == "y" ]]; then
    git commit -m "Init ${LIB_NAME} library"
fi

echo
echo "Done! ${LIB_NAME} is ready. Activate the venv with: source .venv/bin/activate"
